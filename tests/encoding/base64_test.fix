module Base64Test;

import Minilib.Common.TimeEx;
import Minilib.Encoding.Base64;
import Minilib.Text.StringEx;
import Minilib.Text.Hex;
import Minilib.Testing.UnitTest;

test_base64_encode: TestCase;
test_base64_encode = (
    make_table_test("test_base64_encode",
        [
            ("", ""),
            ("69", "aQ=="),     // not "ab=="
            ("69b7", "abc="),
            ("69b71d", "abcd"),
            ("fedcba9876543210", "/ty6mHZUMhA="),
            ("fedcba98765432", "/ty6mHZUMg=="),     // not "/ty6mHZUMhA=="
            ("fedcba987654", "/ty6mHZU"), // not "/ty6mHZUM"
            ("6b3019d3dfbf", "azAZ09+/"),
            // rfc3548 7.  Illustrations and examples
            ("14fb9c03d97e", "FPucA9l+"),
            ("14fb9c03d9", "FPucA9k="),
            ("14fb9c03", "FPucAw=="),
        ],
        |(hex, base64)|
        let bytes = *from_string_hex(hex).from_result;
        let actual = base64_encode(bytes);
        assert_equal("eq", base64, actual)
    )
);

test_base64_decode: TestCase;
test_base64_decode = (
    make_table_test("test_base64_decode",
        [
            ("", ""),
            ("a", ""),
            ("ab==", "69"),
            ("abc=", "69b7"),
            ("abcd", "69b71d"),
            ("/ty6mHZUMhA=", "fedcba9876543210"),
            ("  /t y 6 mH ?!? Z U M h A= ", "fedcba9876543210"),
            ("azAZ09+/", "6b3019d3dfbf"),
            // rfc3548 7.  Illustrations and examples
            ("FPucA9l+", "14fb9c03d97e"),
            ("FPucA9k=", "14fb9c03d9"),
            ("FPucAw==", "14fb9c03"),
        ],
        |(base64, hex)|
        let bytes = base64_decode(base64);
        let actual = bytes.to_string_hex;
        assert_equal("eq", hex, actual)
    )
);

test_base64_perf: TestCase;
test_base64_perf = (
    make_test("test_base64_perf") $ |_|
    let time_limit = 0.3;
    let n = 1e6;
    let bytes = Array::from_map(n, ToU8::u8);
    let (base64, time) = *measure_time(time_limit, |_| base64_encode(bytes));
    println((n, time).format("test_base64_perf: encode n={} time={} sec")).lift;;
    let (bytes2, time) = *measure_time(time_limit, |_| base64_decode(base64));
    println((n, time).format("test_base64_perf: decode n={} time={} sec")).lift;;
    assert_equal("eq", bytes, bytes2)
);

main: IO ();
main = (
    [
        test_base64_encode,
        test_base64_decode,
        test_base64_perf,
    ]
    .run_test_driver
);

